# Vercel 部署时请在 Vercel 控制台的 Environment Variables 中设置以下值：
# VITE_API_BASE_URL=https://<your-railway-service>.up.railway.app
# VITE_GOOGLE_CLIENT_ID=your-google-client-id
#
# 示例：
# VITE_API_BASE_URL=https://api.learnpathly.com
# VITE_SITE_URL=https://www.learnpathly.com
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
 
# 生产默认指向 api 子域名（也可在 Vercel 控制台用同名环境变量覆盖）
VITE_API_BASE_URL=https://api.learnpathly.com
VITE_SITE_URL=https://www.learnpathly.com
VITE_GOOGLE_CLIENT_ID=
VITE_GA_MEASUREMENT_ID=
